// Reference: https://containers.dev/implementors/json_reference/
// Templates: https://github.com/devcontainers/templates/tree/main/src/debian
// Image:     https://github.com/devcontainers/images/tree/main/src/base-debian
{
  "name": "BhExt: Behat TYPO3 Extension (DinD environment)",
  // https://hub.docker.com/_/debian
  "image": "debian:bookworm-slim",
  // https://containers.dev/features
  "features": {
    // https://github.com/devcontainers/features/tree/main/src/common-utils
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true,
      "username": "developer",
      "userUid": "1000",
      "userGid": "1000"
    },
    // https://github.com/devcontainers/features/tree/main/src/git
    "ghcr.io/devcontainers/features/git:1": {},
    // https://github.com/devcontainers/features/tree/main/src/docker-in-docker
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "29.5",
      "moby": false
    }
  },
  // Benutzer- und Shell-Konfiguration
  "containerUser": "developer",
  // Portforwarding
  "forwardPorts": [
    8801,
    7901
  ],
  // VS Code Extensions
  "customizations": {
    "vscode": {
      "extensions": [
        "alexkrechik.cucumberautocomplete",
        "bmewburn.vscode-intelephense-client",
        "esbenp.prettier-vscode",
        "ms-vscode.makefile-tools",
        "xdebug.php-debug"
      ]
    }
  },
  // Lifecycle scripts: https://containers.dev/implementors/json_reference/#lifecycle-scripts
  "postCreateCommand": {
    "tools": "sudo apt-get update -qq && sudo apt-get install -y --no-install-recommends make",
    "zsh": "cp ~/.oh-my-zsh/templates/zshrc.zsh-template ~/.zshrc"
  }
}